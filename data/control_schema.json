{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "control",
  "title": "ControlIndexItem",
  "description": "控件索引项",
  "type": "object",
  "required": ["displayName", "image", "width", "height"],
  "properties": {
    "displayName": {
      "type": "string",
      "description": "控件显示名称"
    },
    "image": {
      "type": "string",
      "description": "控件资源路径（symbols/ 或 assets/ 下的 JSON 或图片文件）"
    },
    "width": {
      "type": ["number", "null"],
      "description": "控件宽度"
    },
    "height": {
      "type": ["number", "null"],
      "description": "控件高度"
    },
    "boundExtend": {
      "type": "number",
      "description": "边界扩展像素值"
    }
  },
  "additionalProperties": false
}
